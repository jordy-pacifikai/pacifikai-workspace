{
  "manifest_version": 3,
  "name": "Ve'a Connect",
  "version": "1.0.0",
  "description": "Connecte ta Page Facebook a Ve'a en un clic. L'extension detecte automatiquement ton Page Access Token et l'envoie a ton dashboard Ve'a.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Ve'a Connect",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["tabs", "storage", "scripting", "alarms"],
  "host_permissions": [
    "https://vea.pacifikai.com/*",
    "https://business.facebook.com/*",
    "https://www.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://business.facebook.com/*",
        "https://www.facebook.com/business/*"
      ],
      "js": ["content/business-fb.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  }
}
